rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email']) &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 100;
      }

      function isNotUpdatingRole() {
        return !incoming().diff(existing()).affectedKeys().hasAny(['role']) || isAdmin();
      }
      
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && 
                    (!('role' in incoming()) || incoming().role == 'customer' || isAdmin());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && 
                    isNotUpdatingRole() &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['shopName', 'ownerName', 'firstName', 'lastName', 'location', 'photoUrl', 'phone', 'lat', 'lng', 'activeShopId', 'updatedAt', 'addresses', 'paymentMethods', 'role', 'createdAt', 'uid', 'email']);
    }

    // --- Shops ---
    match /shops/{shopId} {
      function isValidShop(data) {
        return data.keys().hasAll(['id', 'ownerId', 'name', 'address']) &&
               data.ownerId == request.auth.uid &&
               data.name is string && data.name.size() <= 100 &&
               data.address is string && data.address.size() <= 200;
      }

      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid) && isValidId(shopId);
      allow create: if isSignedIn() && isValidId(shopId) && isValidShop(incoming());
      allow update: if isSignedIn() && existing().ownerId == request.auth.uid && isValidShop(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'address', 'photoUrl', 'managerName', 'contactNumber', 'lat', 'lng']);
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Orders ---
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.userId == request.auth.uid &&
               data.items is list && data.items.size() > 0 &&
               data.totalAmount is number &&
               data.createdAt == request.time &&
               data.status in ['Order Confirmed', 'Being Packed', 'Out for Delivery', 'Delivered'];
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid && isValidId(orderId);
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                    incoming().userId == existing().userId &&
                    (!('updatedAt' in incoming()) || incoming().updatedAt == request.time);
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid && isValidId(notificationId);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
    }

    // --- FCM Tokens ---
    match /fcmTokens/{tokenId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
    }
  }
}
